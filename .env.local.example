# Copy to .env.local and fill in.

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME"
# Set to "true" only if that Postgres requires TLS (most self-hosted ones don't)
DATABASE_SSL="false"

# Auth.js secret — generate with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"

# Google OAuth credentials (Google Cloud Console -> Credentials -> OAuth client)
AUTH_GOOGLE_ID="xxxxxxxx.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="xxxxxxxx"

# Public base URL. Use http://localhost:3000 in dev; your real domain in prod.
AUTH_URL="http://localhost:3000"

# Used by scripts/create-admin.mjs to seed the first super admin
ADMIN_EMAIL="admin@your-domain.com"
ADMIN_PASSWORD="change-this-strong-password"
ADMIN_NAME="Super Admin"
